---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Documentation" description="Citelines technical documentation">
  <h1 style="margin-bottom: 2rem;">Documentation</h1>

  <section style="margin-bottom: 3rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">Source Code</h2>
    <p style="color: #555; line-height: 1.7;">
      <a href="https://github.com/citelines/youtube-annotator" target="_blank" rel="noopener" style="color: #0497a6;">github.com/citelines/youtube-annotator</a>
    </p>
    <p>
      <a href="https://github.com/citelines/youtube-annotator/issues" target="_blank" rel="noopener" style="color: #0497a6;">Report an issue</a>
    </p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">Stack</h2>
    <p style="color: #555; line-height: 1.7;"></p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">Claude Code</h2>
    <p style="color: #555; line-height: 1.7;"></p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">In Progress</h2>
    <p style="color: #555; line-height: 1.7;"></p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">Future Work</h2>

    <h3 style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">CSL</h3>
    <p style="color: #555; line-height: 1.7;"></p>

    <h3 style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">Archive.org S3</h3>
    <p style="color: #555; line-height: 1.7;"></p>

    <h3 style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">Player and Browser Support</h3>
    <p style="color: #555; line-height: 1.7;"></p>
  </section>
</Layout>
