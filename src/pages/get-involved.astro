---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Involved" description="Get involved with Citelines">
  <h1 style="margin-bottom: 2rem;">Get Involved</h1>

  <nav class="toc" aria-label="Table of contents">
    <ul>
      <li><a href="#use-the-plugin">Use the Plugin</a></li>
      <li class="nested"><a href="#get-the-plugin">Get the Plugin</a></li>
      <li class="nested"><a href="#video-viewers">Video Viewers</a></li>
      <li class="nested"><a href="#video-creators">Video Creators</a></li>
      <li><a href="#educators">Educators</a></li>
      <li><a href="#developers">Developers</a></li>
      <li><a href="#email">Email</a></li>
      <li><a href="#donate">Donate</a></li>
      <li><a href="#contact">Contact Us</a></li>
    </ul>
  </nav>

  <section style="margin-bottom: 3rem;">
    <h2 id="use-the-plugin" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Use the Plugin</h2>
    <h3 id="get-the-plugin" style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">Get the Plugin</h3>
    <p style="color: #555; line-height: 1.7; margin-bottom: 1.5rem;">Install the Citelines Chrome extension to view and add citations on YouTube videos.</p>

    <ol style="color: #555; line-height: 1.8; padding-left: 1.25rem;">
      <li style="margin-bottom: 1.5rem;">
        <strong>Download the Extension</strong><br />
        Go to the <a href="https://github.com/citelines/citelines-extension" style="color: #0497a6;">Citelines Extension GitHub repo</a>. Click the green <strong>Code</strong> button, then <strong>Download ZIP</strong>. Open the ZIP to get the <code>citelines-extension-master</code> folder.
        <br /><img src="/images/download-zip.png" alt="GitHub Download ZIP button" style="max-width: 500px; margin-top: 0.75rem; border: 1px solid #ddd; border-radius: 4px;" />
      </li>
      <li style="margin-bottom: 1.5rem;">
        <strong>Open Chrome Extensions Page</strong><br />
        Navigate to <code>chrome://extensions</code> in your Chrome browser.
      </li>
      <li style="margin-bottom: 1.5rem;">
        <strong>Enable Developer Mode</strong><br />
        Toggle the <strong>Developer mode</strong> switch in the top-right corner.
        <br /><img src="/images/chrome-extensions-tab.png" alt="Chrome extensions page with Developer mode and Load unpacked" style="max-width: 500px; margin-top: 0.75rem; border: 1px solid #ddd; border-radius: 4px;" />
      </li>
      <li style="margin-bottom: 1.5rem;">
        <strong>Load the extension</strong><br />
        Click <strong>Load unpacked</strong> (shown in the screenshot above) and select the <code>citelines-extension-master</code> folder.
      </li>
    </ol>
<h3 id="video-viewers" style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">Video Viewers</h3>
    <p style="color: #555; line-height: 1.7;">After installing the plugin:</p>
    <ol style="color: #555; line-height: 1.8; padding-left: 1.25rem;">
      <li>
        <strong>Go to YouTube</strong><br />
        View any YouTube video.
        <ul>
          <li>The appearance of <strong>three buttons</strong> in the bottom right of the video player means the plugin is loaded.</li>
          <li>If this is your first time using Citelines, or if you have not created an account, those icons will be <strong>grey</strong>. You do not need an account to use Citelines.</li>
          <li>To <strong>create or log into an account</strong>, click the button with the silhouette on it. If you are logged in to your Citelines account, these buttons will be <strong>teal</strong>. If you have connected your YouTube account, and are viewing a video that you created, they will be <strong>orange</strong>.</li>
          <li>To <strong>add a citation</strong>, move the the video player's playhead to the desired timestamp. Then click the "+" button.
          <li>To <strong>view citations</strong>, click on the triangular markers that appear on the progress bar. If no citations exist on the video yet, there will be no markers. The markers' color corresponds to user ownership described above.</li>
          <li>To view the <strong>bibliography</strong> of the video, click the button with three lines on it. It presents all citations on the video in chronological order.</li>
        </ul>
        <br />
        <div style="display: flex; align-items: flex-end; gap: 1.5rem; margin-top: 0.75rem; flex-wrap: wrap;">
          <img src="/images/initiated-citelines-ux.png" alt="View of the Citelines plugin on a blank YouTube video." style="max-width: 500px; border: 1px solid #ddd; border-radius: 4px;" />
          <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
            <div style="display: flex; flex-direction: column; align-items: center; gap: 2px;">
              <svg width="36" height="36" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                <circle cx="18" cy="18" r="18" fill="rgba(4, 151, 166, 0.9)" />
                <circle cx="18" cy="13" r="4.5" fill="none" stroke="#000" stroke-width="1.5" />
                <path d="M9 27.5a9 9 0 0 1 18 0" fill="none" stroke="#000" stroke-width="1.5" stroke-linecap="round" />
              </svg>
              <span style="font-size: 0.7rem; color: #888;">Account</span>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 2px;">
              <svg width="36" height="36" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                <circle cx="18" cy="18" r="18" fill="rgba(4, 151, 166, 0.9)" />
                <line x1="11" y1="12" x2="25" y2="12" stroke="#000" stroke-width="2" stroke-linecap="round" />
                <line x1="11" y1="18" x2="25" y2="18" stroke="#000" stroke-width="2" stroke-linecap="round" />
                <line x1="11" y1="24" x2="25" y2="24" stroke="#000" stroke-width="2" stroke-linecap="round" />
              </svg>
              <span style="font-size: 0.7rem; color: #888;">Bibliography</span>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: 2px;">
              <svg width="36" height="36" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                <circle cx="18" cy="18" r="18" fill="rgba(4, 151, 166, 0.9)" />
                <line x1="18" y1="10" x2="18" y2="26" stroke="#000" stroke-width="2.5" stroke-linecap="round" />
                <line x1="10" y1="18" x2="26" y2="18" stroke="#000" stroke-width="2.5" stroke-linecap="round" />
              </svg>
              <span style="font-size: 0.7rem; color: #888;">Add Citation</span>
            </div>
          </div>
        </div>
      </li>
    </ol>
<h3 id="video-creators" style="font-size: 1.15rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: #1a1a1a;">Video Creators</h3>
    <p style="color: #555; line-height: 1.7;">After installing the plugin:</p>

    <ol style="color: #555; line-height: 1.8; padding-left: 1.25rem;">
      <li>
        <strong>Connect Your YouTube Account</strong><br />
        <ul>
          <li>Click on the Citelines extension icon in your browser, then click <strong>Connect YouTube</strong> to link your YouTube channel to your Citelines account. This allows Citelines to recognize you as the creator of your videos, so your citations will appear in orange to all viewers.</li>
        </ul>
      </li>
      <li>
        <strong>Go to YouTube</strong><br />
        <ul>
          <li>Perform your normal upload and/or edit steps for a YouTube video you've created. On the "Video Details" page, you should see the Citelines creator tools panel on the right side of the screen, where you can add citations to your video.</li>
          <li>Upon clicking the <strong>Add Citation</strong> button, you can navigate to your YouTube video and you will see your citations, in orange, as triangular markers on the progress bar.</li>
          <li>Adding citations from the Studio / Video Details page is more efficient for a video creator. However, you can also add citations simply from viewing the video, like any other Citelines viewer.</li>
        </ul>
        <br /><img src="/images/creator-tools-sidebar.png" alt="Citelines creator tools righthand sidebar as seen in YouTube Studio, Video Details page" style="max-width: 250px; margin-top: 0.75rem; border: 1px solid #ddd; border-radius: 4px;" />
      </li>
    </ol>
  </section>

  <section style="margin-bottom: 3rem;">
    <p style="color: #555; line-height: 1.7;"></p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 id="educators" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Educators</h2>
    <p style="color: #555; line-height: 1.7;">More information coming soon.</p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2 id="developers" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Developers</h2>
    <p style="color: #555; line-height: 1.7;">More information coming soon.</p>
  </section>
  <section style="margin-bottom: 3rem;">
    <h2 id="email" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Email</h2>
    <p style="color: #555; line-height: 1.7;">More information coming soon.</p>
  </section>
  <section style="margin-bottom: 3rem;">
    <h2 id="donate" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Donate</h2>
    <p style="color: #555; line-height: 1.7;">More information coming soon.</p>
  </section>
  <section style="margin-bottom: 3rem;">
    <h2 id="contact" style="font-size: 1.5rem; margin-bottom: 0.75rem;">Contact Us</h2>
    <p style="color: #555; line-height: 1.7;">More information coming soon.</p>
  </section>

</Layout>

<style>
  .toc {
    position: fixed;
    top: 120px;
    left: max(1rem, calc((100vw - 860px) / 2 - 260px));
    width: 220px;
    max-height: calc(100vh - 160px);
    overflow-y: auto;
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid #eee;
    padding-left: 0.75rem;
  }

  .toc li {
    margin-bottom: 0.35rem;
  }

  .toc li.nested {
    padding-left: 0.75rem;
  }

  .toc a {
    color: #888;
    text-decoration: none;
    transition: color 0.15s;
  }

  .toc a:hover {
    color: #222;
  }

  .toc a.active {
    color: #0497a6;
    font-weight: 600;
  }

  @media (max-width: 1440px) {
    .toc {
      display: none;
    }
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc a');
  if (tocLinks.length > 0) {
    const ids = Array.from(tocLinks).map(a => a.getAttribute('href').slice(1));
    const headings = ids
      .map(id => document.getElementById(id))
      .filter(el => el !== null);

    function updateActiveToc() {
      let current = headings[0];
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= 100) {
          current = h;
        } else {
          break;
        }
      }
      tocLinks.forEach(a => a.classList.remove('active'));
      if (current) {
        const active = document.querySelector(`.toc a[href="#${current.id}"]`);
        if (active) active.classList.add('active');
      }
    }

    window.addEventListener('scroll', updateActiveToc, { passive: true });
    updateActiveToc();
  }
</script>
