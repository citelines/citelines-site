---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Citelines — verified citations for online video">
  <div class="hero">
    <p>A browser extension that creates a collaborative citation tool on videos.</p>

    <a href="/get-involved#get-the-plugin" class="btn-cta">Get the Plugin</a>

    <img src="/images/heimlich_demo.png" alt="Screenshot of the Citelines browser extension on a YouTube video, showing citation markers and a citation popup" class="hero-screenshot" />

    <div class="hero-quote-block">
      <h3 class="hero-quote">&ldquo;Quoting is what we do to bring in the voices of others, to expand the frame, not to narrow it.&rdquo;</h3>
      <div class="hero-citation">
        <div class="hero-citation-marker" aria-hidden="true"></div>
        <div class="hero-citation-card">
          <div class="hero-citation-icon">📄</div>
          <div class="hero-citation-info">
            <span class="hero-citation-title">Doppelganger: A Trip into the Mirror World</span>
            <span class="hero-citation-meta">Naomi Klein · 2023</span>
            <span class="hero-citation-meta">Farrar, Straus, and Giroux · pp. 70</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    .hero {
      text-align: center;
      padding: 4rem 0;
    }

    .hero-quote-block {
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    .hero-quote {
      font-size: 1.75rem;
      font-weight: 700;
      line-height: 1.3;
      color: #1a1a1a;
      letter-spacing: -0.01em;
      margin: 0 0 1.5rem;
    }

    .hero-citation {
      display: flex;
      align-items: flex-start;
      justify-content: flex-end;
    }

    .hero-citation-marker {
      width: 0;
      height: 0;
      border-left: 7px solid transparent;
      border-right: 7px solid transparent;
      border-bottom: 11px solid #0497a6;
      filter: drop-shadow(0 0 4px rgba(4, 151, 166, 0.5));
      flex-shrink: 0;
      margin-top: 10px;
      margin-right: 10px;
    }

    .hero-citation-card {
      display: flex;
      gap: 10px;
      padding: 6px 16px;
      background: #fafafa;
      border-radius: 8px;
      border-left: 3px solid #0497a6;
      text-align: left;
    }

    .hero-citation-icon {
      font-size: 20px;
      flex-shrink: 0;
      line-height: 1;
    }

    .hero-citation-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .hero-citation-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: #1a1a1a;
    }

    .hero-citation-meta {
      font-size: 0.8rem;
      color: #888;
    }

    .hero-screenshot {
      display: block;
      max-width: 100%;
      margin: 2.5rem auto 2.5rem;
      border: 1px solid #ddd;
      border-radius: 8px;
    }

    .btn-cta {
      display: inline-block;
      margin-top: 2rem;
      padding: 0.9rem 2.5rem;
      background: #1a1a1a;
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .btn-cta:hover {
      background: #333;
    }

    @media (max-width: 720px) {
      .hero {
        padding: 2rem 0;
      }

      .hero-quote {
        font-size: 1.35rem;
      }
    }
  </style>
</Layout>
