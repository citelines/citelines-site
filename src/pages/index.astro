---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Citelines — verified citations for online video">
  <div class="hero">
    <div class="quote-block">
      <blockquote class="quote-text">"Expand the frame."</blockquote>
      <div class="citation-card">
        <div class="citation-marker" aria-hidden="true"></div>
        <div class="citation-body">
          <div class="citation-icon">📄</div>
          <div class="citation-content">
            <span class="citation-title">Doppelganger: A Trip into the Mirror World</span>
            <span class="citation-meta">Naomi Klein · 2023</span>
            <span class="citation-meta">Farrar, Straus, and Giroux</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#" class="btn-cta">Get the Plugin</a>

    <div class="secondary">
      <a href="#" class="btn-secondary">Buy us a coffee</a>

      <form class="subscribe-form" onsubmit="event.preventDefault()">
        <input type="email" placeholder="you@example.com" required />
        <button type="submit" class="btn-secondary">Subscribe</button>
      </form>
    </div>
  </div>

  <style is:global>
    .hero {
      text-align: center;
      padding: 6rem 0;
    }

    .quote-block {
      max-width: 640px;
      margin: 0 auto;
      position: relative;
      padding-bottom: 5rem;
    }

    .quote-text {
      font-size: 2.75rem;
      font-weight: 700;
      line-height: 1.2;
      color: #1a1a1a;
      letter-spacing: -0.02em;
      margin: 0;
      border: none;
      padding: 0;
    }

    .citation-card {
      position: absolute;
      bottom: 0;
      right: 0;
      display: flex;
      align-items: flex-start;
      gap: 0;
      text-align: left;
    }

    .citation-marker {
      width: 0;
      height: 0;
      border-left: 7px solid transparent;
      border-right: 7px solid transparent;
      border-bottom: 11px solid #0497a6;
      filter: drop-shadow(0 0 4px rgba(4, 151, 166, 0.5));
      flex-shrink: 0;
      margin-top: 10px;
      margin-right: 10px;
    }

    .citation-body {
      display: flex;
      gap: 10px;
      padding: 12px 16px;
      background: #fafafa;
      border-radius: 8px;
      border-left: 3px solid #0497a6;
    }

    .citation-icon {
      font-size: 20px;
      flex-shrink: 0;
      line-height: 1;
    }

    .citation-content {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .citation-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: #1a1a1a;
    }

    .citation-meta {
      font-size: 0.8rem;
      color: #888;
    }

    .btn-cta {
      display: inline-block;
      margin-top: 3rem;
      padding: 0.9rem 2.5rem;
      background: #1a1a1a;
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .btn-cta:hover {
      background: #333;
    }

    .secondary {
      margin-top: 2.5rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
    }

    .btn-secondary {
      display: inline-block;
      padding: 0.55rem 1.25rem;
      border: 1px solid #ccc;
      border-radius: 6px;
      background: #fff;
      color: #555;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
    }

    .btn-secondary:hover {
      border-color: #999;
      color: #1a1a1a;
    }

    .subscribe-form {
      display: flex;
      gap: 0.5rem;
    }

    .subscribe-form input {
      padding: 0.55rem 0.75rem;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 0.85rem;
      width: 200px;
    }

    .subscribe-form input:focus {
      outline: none;
      border-color: #999;
    }
  </style>
</Layout>
