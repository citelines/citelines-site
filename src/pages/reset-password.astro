---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reset Password" description="Reset your Citelines password">
  <div id="reset-container" style="max-width: 400px; margin: 0 auto; padding: 2rem 0;">
    <h1 style="text-align: center; margin-bottom: 0.5rem;">Reset Password</h1>
    <p style="text-align: center; color: #666; margin-bottom: 2rem;">Enter your new password below.</p>

    <div id="message" style="display: none; padding: 0.75rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem;"></div>

    <form id="resetForm">
      <div style="margin-bottom: 1.25rem;">
        <label for="newPassword" style="display: block; margin-bottom: 0.35rem; font-weight: 500; font-size: 0.9rem;">New Password</label>
        <input type="password" id="newPassword" required minlength="8" autocomplete="new-password"
          style="width: 100%; padding: 0.6rem; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem;">
      </div>
      <div style="margin-bottom: 1.25rem;">
        <label for="confirmPassword" style="display: block; margin-bottom: 0.35rem; font-weight: 500; font-size: 0.9rem;">Confirm Password</label>
        <input type="password" id="confirmPassword" required minlength="8" autocomplete="new-password"
          style="width: 100%; padding: 0.6rem; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem;">
      </div>
      <button type="submit" id="submitBtn"
        style="width: 100%; padding: 0.75rem; background: #0497a6; color: white; border: none; border-radius: 4px; font-size: 0.9rem; font-weight: 500; cursor: pointer;">
        Reset Password
      </button>
    </form>
  </div>

  <script>
    const API_URL = 'https://citelines-extension-production.up.railway.app';
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const msg = document.getElementById('message');
    const form = document.getElementById('resetForm');

    function showMessage(text, type) {
      msg.textContent = text;
      msg.style.display = 'block';
      if (type === 'error') {
        msg.style.background = '#f8d7da';
        msg.style.color = '#721c24';
      } else {
        msg.style.background = '#d4edda';
        msg.style.color = '#155724';
      }
    }

    if (!token) {
      showMessage('Invalid reset link. No token provided.', 'error');
      form.style.display = 'none';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const newPassword = (document.getElementById('newPassword') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;
      const btn = document.getElementById('submitBtn') as HTMLButtonElement;

      msg.style.display = 'none';

      if (newPassword !== confirmPassword) {
        showMessage('Passwords do not match.', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Resetting...';

      try {
        const res = await fetch(`${API_URL}/api/auth/reset-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, newPassword })
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || data.message || 'Reset failed');
        }

        showMessage('Password reset successfully. You can now sign in with your new password.', 'success');
        form.style.display = 'none';
      } catch (error) {
        showMessage(error.message, 'error');
        btn.disabled = false;
        btn.textContent = 'Reset Password';
      }
    });
  </script>
</Layout>
